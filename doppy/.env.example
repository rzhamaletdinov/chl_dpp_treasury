# Copy this file to `.env` and fill in real values before running `npm run deploy:*`.
# `.env` is git-ignored.
#
# IMPORTANT: before any deploy is even possible, set the GNOSIS owner address
# inside contracts/Treasury.sol (search for `TODO(doppy)`). Until that constant
# is non-zero, `initialize` reverts with "Ownable: new owner is the zero address".

# --- RPC ---
# Optional. If unset, defaults from hardhat.config.js are used (public RPC).
BSC_RPC_URL=https://bsc-dataseed.binance.org
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545

# --- Deployer ---
# Hex private key WITHOUT the 0x prefix is also accepted by Hardhat,
# but with 0x is fine too. NEVER commit a real key.
PRIVATE_KEY=

# --- Contract verification (optional) ---
BSCSCAN_API_KEY=

# --- Treasury.initialize(...) arguments ---
# Custom NFT contracts deployed by the Doppy project.
# Both must implement CustomNFT (IERC721EnumerableUpgradeable + receiveNFT).
CASES=
GLASSES=

# Off-chain signer that signs withdrawal payloads.
SIGNER=

# ERC20 token addresses managed by the Treasury.
DOPPY=
BNH=
USDT=
